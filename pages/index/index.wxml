<!--index.wxml-->
<navigation-bar title="" back="{{false}}" color="#1c1917" background="hsl(33, 100%, 96%, 80%)"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list" bindtap="onContainerTap" bindscroll="onScroll" scroll-into-view="{{scrollIntoView}}">
  <view class="journal-container">
    <view class="journal-list" wx:for="{{formatJournals}}" wx:for-index="idx" wx:for-item="journalData" wx:key="idx">
      <view class="journal-item" id="{{'day-'+idx}}">
        <!-- 日期显示 -->
        <view class="title">{{idx}}</view>
        <!-- 内容列表 -->
        <swipe-delete wx:for="{{journalData}}" wx:key="id" data-id="{{item.id}}" index="{{item.id}}" data-class="content-swipe" bind:delete="onDeleteJournal" bind:open="onSwipeOpen" class="content-swipe" current-open="{{currentOpenIndex}}">
          <view class="content-item" bindtap="onEditJournal" data-id="{{item.id}}" data-class="content-item">
            <text class="content-text" data-class="content-text">{{item.content}}</text>
          </view>
        </swipe-delete>
      </view>
    </view>
  </view>
</scroll-view>
<view class="bottom-bar" bindtap="onContainerTap">
  <view class="icon chart-icon" bindtap="goToStats">
    <text></text>
  </view>
  <button class="add-btn" bindtap="showEditModal">
    + 记录成就
  </button>
  <view class="icon setting-icon" bindtap="goToSettings">
    <text></text>
  </view>
</view>
<!-- 编辑弹窗 -->
<custom-modal title="{{isEdit ? '编辑' : '记录新成就'}}" show="{{showModal}}" expanded="{{focus}}" bindconfirm="onSaveJournal" bindcancel="hideEditModal">
  <textarea auto-focus="true" focus="{{focus}}" placeholder="每一个小成功都值得被记录^_^" value="{{currentJournal.content}}" bindinput="onJournalInput" maxlength="260"></textarea>
  <!-- <view class="editor-tools">
    <text class="word-count">字数：{{currentWordCount}}</text>
  </view> -->
  <scroll-view class="template-list" scroll-x>
    <view class="template-chip" wx:for="{{templates}}" wx:key="*this" bindtap="onTemplatePick" data-template="{{item}}">{{item}}</view>
  </scroll-view>
</custom-modal>
